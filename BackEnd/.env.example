# Copy to .env and fill in. The server runs fine WITHOUT a key —
# compliance analysis and the chat assistant fall back to deterministic
# local logic. Set the key to enable real Claude-powered analysis.
ANTHROPIC_API_KEY=

# Optional overrides
PORT=4000
# Comma-separated allowed origins for CORS (defaults to all in dev)
CORS_ORIGIN=
# Model id (defaults to claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# ── Email notifications (approve/reject → vendor) ────────────────────────────
# Leave SMTP_* blank to use Ethereal (captures mail, returns a preview URL).
# Fill them to deliver for real (Gmail needs a 16-char App Password).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ComplAI <no-reply@complai.app>
# Recipient when a product has no vendor email:
NOTIFY_EMAIL=
